{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "CollapseLoader",
    "version": "0.3.0",
    "identifier": "org.collapseloader",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "CollapseLoader",
                "width": 900,
                "height": 500,
                "minHeight": 400,
                "minWidth": 750,
                "decorations": false
            }
        ],
        "security": {
            "csp": null
        },
        "withGlobalTauri": true
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "dmg": {
                "background": "./dmg-background/background.png"
            }
        }
    },
    "plugins": {
        "deep-link": {
            "desktop": {
                "schemes": [
                    "collapseloader"
                ]
            }
        }
    }
}
